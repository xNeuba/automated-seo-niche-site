---
interface Props {
  productName: string;
  link: string;
  price?: string;
  description: string;
}

const { productName, link, price, description } = Astro.props;
---

<div class="affiliate-box border-2 border-emerald-500 rounded-lg p-6 my-8 bg-emerald-50 shadow-md">
  <h3 class="text-2xl font-bold text-emerald-800 mb-2">{productName}</h3>
  <p class="text-gray-700 mb-4">{description}</p>
  {price && <p class="text-lg font-semibold text-emerald-900 mb-4">Preis ca.: {price}</p>}
  <a 
    href={link} 
    target="_blank" 
    rel="nofollow noopener" 
    class="inline-block bg-emerald-600 text-white font-bold py-3 px-6 rounded-lg hover:bg-emerald-700 transition"
  >
    Jetzt bei Amazon ansehen
  </a>
</div>

<style>
  .affiliate-box {
    transition: transform 0.2s;
  }
  .affiliate-box:hover {
    transform: translateY(-2px);
  }
</style>
