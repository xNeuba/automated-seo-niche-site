---
const { title } = Astro.props;
---
<html lang="de">
<head>
    <meta charset="utf-8">
    <title>{title} | DIY Gadget Magazin</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; line-height: 1.6; max-width: 800px; margin: 0 auto; padding: 20px; color: #333; }
        header { border-bottom: 2px solid #eee; padding-bottom: 20px; margin-bottom: 40px; display: flex; justify-content: space-between; align-items: center; }
        nav a { margin-left: 15px; text-decoration: none; color: #e67e22; font-weight: bold; }
        h1 { color: #2c3e50; }
        h2 { color: #e67e22; margin-top: 30px; }
        .affiliate-box { background: #f9f9f9; padding: 15px; border-left: 5px solid #e67e22; margin: 20px 0; border-radius: 4px; }
        footer { margin-top: 50px; font-size: 0.8em; text-align: center; color: #888; }
    </style>
</head>
<body>
    <header>
        <a href="/" style="text-decoration:none; color:#2c3e50; font-size: 1.5rem; font-weight: bold;">DIY Gadget Magazin</a>
        <nav>
            <a href="/">Home</a>
        </nav>
    </header>
    <article>
        <slot />
    </article>
    <footer>
        &copy; {new Date().getFullYear()} DIY Gadget Magazin
    </footer>
</body>
</html>
